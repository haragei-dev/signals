{
  "explorer.autoRevealExclude": {
    "**/node_modules": true
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.test.ts",
    "*.tsx": "${capture}.test.tsx",
    "*.d.ts": "${capture}.map",
    "package.json": ".git*, .editorconfig, .eslint*, .node-version, .pnpm*, pnpm-*, .prettier*, .vscode*, eslint*, prettier*, tsconfig.json, *.log, vite*.config.ts, turbo.json, lefthook.yml, tsdown.config.ts"
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "prettier.prettierPath": "node_modules/prettier",
  "cSpell.words": [
    "ampproject",
    "arethetypeswrong",
    "attw",
    "doublestar",
    "esbuild",
    "haragei",
    "lefthook",
    "nonconstructor",
    "pkgroll",
    "postpublish",
    "Preact",
    "ruleset",
    "todoapp",
    "todomvc",
    "tsdown",
    "vite",
    "vitest"
  ],
  "references.preferredLocation": "peek",
  "json.schemaDownload.trustedDomains": {
    "https://unpkg.com/@changesets": true,
    "https://*.turborepo.dev": true
  }
}
