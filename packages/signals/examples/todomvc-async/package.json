{
  "name": "@haragei/signals-example-todomvc-async",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:client": "vite",
    "dev:server": "node --watch --import tsx ./server/index.ts",
    "serve:server": "node --import tsx ./server/index.ts",
    "build": "vite build",
    "preview": "node --import tsx ./server/index.ts --static-dir=dist",
    "lint": "eslint ./src ./server ./vite.config.ts ./scripts/dev.mjs --config ../../../../eslint.config.js",
    "typecheck": "tsc --noEmit -p ./tsconfig.json"
  },
  "dependencies": {
    "@fastify/static": "^9.1.1",
    "@haragei/signals": "workspace:*",
    "fastify": "^5.0.0",
    "todomvc-app-css": "^2.4.2",
    "todomvc-common": "^1.0.5"
  },
  "devDependencies": {
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
