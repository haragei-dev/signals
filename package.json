{
  "name": "@haragei/signals-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "prepare": "lefthook install",
    "turbo": "turbo",
    "build": "turbo run build",
    "format": "prettier --write --ignore-unknown",
    "format:check": "prettier --check .",
    "lint": "pnpm exec eslint eslint.config.js vitest.config.ts scripts --config ./eslint.config.js && turbo run lint",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "prepublishOnly": "turbo run prepublishOnly",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release:pack": "node ./scripts/pack-public-packages.mjs",
    "release:notes": "node ./scripts/generate-release-notes.mjs",
    "release:publish:npm": "node ./scripts/publish-release-artifacts.mjs --registry=https://registry.npmjs.org --token-env=NPM_TOKEN"
  },
  "devDependencies": {
    "@ampproject/remapping": "catalog:",
    "@arethetypeswrong/core": "catalog:",
    "@changesets/changelog-git": "catalog:",
    "@changesets/cli": "catalog:",
    "@eslint/js": "catalog:",
    "esbuild": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "clean-publish": "catalog:",
    "eslint": "catalog:",
    "glob": "catalog:",
    "globals": "catalog:",
    "happy-dom": "catalog:",
    "lefthook": "catalog:",
    "prettier": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "typescript-eslint-language-service": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
