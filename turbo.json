{
  "$schema": "https://v2-9-2.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["package/dist/**", "dist/**"]
    },
    "lint": {},
    "test": {},
    "test:coverage": {
      "outputs": ["coverage/**"]
    },
    "typecheck": {},
    "prepublishOnly": {
      "dependsOn": ["^prepublishOnly"]
    }
  }
}
